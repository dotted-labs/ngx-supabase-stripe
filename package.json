{
  "name": "@dotted-labs/ngx-supabase-stripe",
  "version": "0.6.5",
  "scripts": {
    "ng": "ng",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test stripe-demo",
    "build:lib": "npm run sync-i18n && ng build ngx-supabase-stripe --project ngx-supabase-stripe",
    "sync-i18n": "cp projects/ngx-supabase-stripe/src/i18n/messages.*.json projects/ngx-supabase-stripe/i18n/src/",
    "extract-i18n:lib": "echo 'extract-i18n is not supported for libraries; edit src/i18n/messages.*.json manually and run sync-i18n'",
    "start:stripe-demo": "ng serve stripe-demo"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/localize": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@dotted-labs/ngx-supabase-auth": "0.3.1",
    "@ngrx/signals": "^21.0.0",
    "@stripe/stripe-js": "^8.8.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/postcss": "^4.1.4",
    "daisyui": "^5.0.28",
    "prettier": "^3.5.3",
    "rxjs": "7.8.1",
    "tailwindcss": "^4.1.6",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@types/node": "^22.13.10",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.4",
    "stripe": "^18.2.0",
    "supabase": "^2.76.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.18"
  }
}
